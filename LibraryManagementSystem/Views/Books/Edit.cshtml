@* Person 3: Edit book page for the admin/librarian module. *@
@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = "Edit Book";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Edit Book</h1>
                <p class="admin-section-copy">Update book metadata, replace its cover image, and control whether the title is currently available.</p>
            </div>
            <a class="btn admin-btn btn-light" asp-action="Index">Back to Books</a>
        </div>

        <div class="admin-form-layout">
            <div class="admin-form-card">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="BookId" />
                    <input type="hidden" asp-for="CoverImagePath" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="admin-form-grid">
                        <div class="admin-field">
                            <label asp-for="Title"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label asp-for="ISBN"></label>
                            <input asp-for="ISBN" class="form-control" />
                            <span asp-validation-for="ISBN" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label asp-for="AuthorId">Author</label>
                            <select asp-for="AuthorId" asp-items="ViewBag.AuthorOptions" class="form-select">
                                <option value="0">Select existing author</option>
                            </select>
                            <span asp-validation-for="AuthorId" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label for="newAuthorName">New Author</label>
                            <input id="newAuthorName" type="text" name="newAuthorName" value="@ViewBag.NewAuthorName" class="form-control" placeholder="Type a new author name if needed" />
                        </div>

                        <div class="admin-field">
                            <label asp-for="GenreId">Genre</label>
                            <select asp-for="GenreId" asp-items="ViewBag.GenreOptions" class="form-select">
                                <option value="0">Select existing genre</option>
                            </select>
                            <span asp-validation-for="GenreId" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label for="newGenreName">New Genre</label>
                            <input id="newGenreName" type="text" name="newGenreName" value="@ViewBag.NewGenreName" class="form-control" placeholder="Type a new genre if needed" />
                        </div>

                        <div class="admin-field full">
                            <label for="coverImage">Replace Cover Image</label>
                            <input id="coverImage" type="file" name="coverImage" accept="image/*" class="form-control" data-preview-target="#coverPreview" />
                            <small>Leave this empty to keep the current book cover.</small>
                        </div>

                        <div class="admin-field full">
                            <div class="form-check">
                                <input asp-for="IsAvailable" class="form-check-input" />
                                <label asp-for="IsAvailable" class="form-check-label">Available for borrowing</label>
                            </div>
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn admin-btn btn-primary">Save Changes</button>
                        <a class="btn admin-btn btn-secondary" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>

            <aside class="admin-side-card">
                <div class="admin-image-preview">
                    <img id="coverPreview" src="@(string.IsNullOrWhiteSpace(Model.CoverImagePath) ? Url.Content("~/images/books/default.svg") : Model.CoverImagePath)" alt="@Model.Title cover" onerror="this.onerror=null;this.src='/images/books/default.svg';" />
                </div>
                <h2 class="h4 mb-3">Current record</h2>
                <ul class="admin-side-list">
                    <li>Book ID: @Model.BookId</li>
                    <li>Use a replacement image only if you want to change the current cover.</li>
                    <li>Availability can also change automatically when a book is borrowed or returned.</li>
                </ul>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
