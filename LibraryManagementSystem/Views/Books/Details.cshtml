@* Person 3: Book details page for admin review. *@
@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = "Book Details";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">@Model.Title</h1>
                <p class="admin-section-copy">Review the saved book details and current borrowing availability.</p>
            </div>
            <div class="admin-btn-group">
                <a class="btn admin-btn btn-primary" asp-action="Edit" asp-route-id="@Model.BookId">Edit</a>
                <a class="btn admin-btn btn-secondary" asp-action="Index">Back to Books</a>
            </div>
        </div>

        <div class="admin-detail-grid">
            <div class="admin-side-card">
                <div class="admin-image-preview">
                    @if (!string.IsNullOrWhiteSpace(Model.CoverImagePath))
                    {
                        <img src="@Model.CoverImagePath" alt="@Model.Title cover" onerror="this.onerror=null;this.src='/images/books/default.svg';" />
                    }
                    else
                    {
                        <span>No cover uploaded</span>
                    }
                </div>
            </div>

            <div class="admin-form-card">
                <dl class="admin-detail-list">
                    <dt>ISBN</dt>
                    <dd>@Model.ISBN</dd>
                    <dt>Author</dt>
                    <dd>@Model.Author?.Name</dd>
                    <dt>Genre</dt>
                    <dd>@Model.Genre?.Name</dd>
                    <dt>Status</dt>
                    <dd>
                        <span class="admin-status-pill @(Model.IsAvailable ? "available" : "unavailable")">
                            @(Model.IsAvailable ? "Available" : "Unavailable")
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</section>
