@* Person 3: Admin book management page. *@
@model IEnumerable<LibraryManagementSystem.Models.Book>
@{
    ViewData["Title"] = "Books";
    var statusFilter = ViewBag.StatusFilter as string ?? "all";
    var activeBorrowers = ViewBag.ActiveBorrowers as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Book Management</h1>
                <p class="admin-section-copy">Manage the library catalog, upload covers, create manual borrowings, and monitor live availability.</p>
            </div>
            <div class="admin-btn-group">
                <a class="btn admin-btn btn-success" asp-action="Create">Add New Book</a>
                <a class="btn admin-btn btn-light" asp-controller="Admin" asp-action="Index">Dashboard</a>
            </div>
        </div>

        <div class="admin-chip-row">
            <div class="admin-stat-chip"><span>Total Books</span><strong>@ViewBag.TotalBooks</strong></div>
            <div class="admin-stat-chip"><span>Available</span><strong>@ViewBag.AvailableBooks</strong></div>
            <div class="admin-stat-chip"><span>Unavailable</span><strong>@ViewBag.UnavailableBooks</strong></div>
        </div>

        <form asp-action="Index" method="get" class="admin-filter-bar">
            <input type="text" name="isbn" value="@ViewBag.SearchIsbn" placeholder="Search by ISBN" />
            <select name="status">
                <option value="all" selected="@(statusFilter == "all")">All books</option>
                <option value="available" selected="@(statusFilter == "available")">Available only</option>
                <option value="unavailable" selected="@(statusFilter == "unavailable")">Unavailable only</option>
            </select>
            <button class="btn admin-btn btn-primary" type="submit">Filter</button>
            <a class="btn admin-btn btn-secondary" asp-action="Index">Clear</a>
        </form>

        <div class="admin-btn-group mb-3">
            <button type="button" class="btn admin-btn btn-secondary" data-bs-toggle="modal" data-bs-target="#borrowModal">Add Manual Borrowing</button>
            <button type="button" class="btn admin-btn btn-info" data-bs-toggle="modal" data-bs-target="#reservationModal">Add Reservation</button>
            <a class="btn admin-btn btn-warning" asp-controller="AdminBorrowRequests" asp-action="Index">View Borrowed Books</a>
            <a class="btn admin-btn btn-light" asp-controller="Reservation" asp-action="Index">View Reservations</a>
        </div>

        @if (TempData["BorrowError"] != null)
        {
            <div class="alert alert-danger">@TempData["BorrowError"]</div>
        }

        @if (TempData["ReservationError"] != null)
        {
            <div class="alert alert-danger">@TempData["ReservationError"]</div>
        }

        <div class="admin-data-panel admin-data-panel-page-scroll">
            <div class="table-scroll">
            <table class="data-table admin-data-table">
                <thead>
                    <tr>
                        <th>Cover</th>
                        <th>Title</th>
                        <th>ISBN</th>
                        <th>Author</th>
                        <th>Genre</th>
                        <th>Status</th>
                        <th>Borrowed By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var bookItem in Model)
                {
                    <tr>
                        <td style="width: 96px;">
                            @if (!string.IsNullOrWhiteSpace(bookItem.CoverImagePath))
                            {
                                <img src="@bookItem.CoverImagePath" alt="@bookItem.Title cover" class="admin-cover-thumb" onerror="this.onerror=null;this.src='/images/books/default.svg';" />
                            }
                            else
                            {
                                <span class="muted">-</span>
                            }
                        </td>
                        <td>@bookItem.Title</td>
                        <td>@bookItem.ISBN</td>
                        <td>@bookItem.Author?.Name</td>
                        <td>@bookItem.Genre?.Name</td>
                        <td>
                            <span class="admin-status-pill @(bookItem.IsAvailable ? "available" : "unavailable")">
                                @(bookItem.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </td>
                        <td>
                            @if (!bookItem.IsAvailable && activeBorrowers.ContainsKey(bookItem.BookId))
                            {
                                @activeBorrowers[bookItem.BookId]
                            }
                            else
                            {
                                <span class="muted">-</span>
                            }
                        </td>
                        <td>
                            <div class="admin-btn-group">
                                <a class="btn btn-sm admin-btn btn-primary" asp-action="Edit" asp-route-id="@bookItem.BookId">Edit</a>
                                <a class="btn btn-sm admin-btn btn-info" asp-action="Details" asp-route-id="@bookItem.BookId">Details</a>
                                <a class="btn btn-sm admin-btn btn-danger" asp-action="Delete" asp-route-id="@bookItem.BookId">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="borrowModal" tabindex="-1" aria-labelledby="borrowModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="borrowModalLabel">Add Borrowing</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Borrow" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Book</label>
                        <select name="bookId" class="form-select" required>
                            <option value="">Select available book</option>
                            @foreach (var bookItem in Model.Where(b => b.IsAvailable))
                            {
                                <option value="@bookItem.BookId">@bookItem.Title (@bookItem.ISBN)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Member ID / Email</label>
                        <input name="userName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Borrow Date</label>
                        <input type="date" name="borrowDate" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Due Date</label>
                        <input type="date" name="dueDate" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn admin-btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn admin-btn btn-primary">Save Borrowing</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="reservationModal" tabindex="-1" aria-labelledby="reservationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reservationModalLabel">Add Reservation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Reservation" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Book</label>
                        <select name="bookId" class="form-select" required>
                            <option value="">Select book</option>
                            @foreach (var bookItem in Model)
                            {
                                <option value="@bookItem.BookId">@bookItem.Title (@bookItem.ISBN)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Member ID / Email</label>
                        <input name="userName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reservation Date</label>
                        <input type="date" name="reservationDate" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn admin-btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn admin-btn btn-primary">Save Reservation</button>
                </div>
            </form>
        </div>
    </div>
</div>
