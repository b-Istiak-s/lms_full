@* Person 3: Delete book confirmation page. *@
@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Delete Book</h1>
                <p class="admin-section-copy">Confirm before removing this title from the library catalog.</p>
            </div>
            <a class="btn admin-btn btn-light" asp-action="Index">Back to Books</a>
        </div>

        <div class="admin-detail-grid">
            <div class="admin-side-card">
                <div class="admin-image-preview">
                    @if (!string.IsNullOrWhiteSpace(Model.CoverImagePath))
                    {
                        <img src="@Model.CoverImagePath" alt="@Model.Title cover" onerror="this.onerror=null;this.src='/images/books/default.svg';" />
                    }
                    else
                    {
                        <span>No cover uploaded</span>
                    }
                </div>
            </div>

            <div class="admin-form-card">
                <h2 class="h4 mb-3">@Model.Title</h2>
                <p class="muted">This action removes the book entry from the admin catalog view.</p>
                <dl class="admin-detail-list">
                    <dt>ISBN</dt>
                    <dd>@Model.ISBN</dd>
                    <dt>Author</dt>
                    <dd>@Model.Author?.Name</dd>
                    <dt>Genre</dt>
                    <dd>@Model.Genre?.Name</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="BookId" />
                    <div class="admin-form-actions">
                        <button type="submit" class="btn admin-btn btn-danger">Delete Book</button>
                        <a class="btn admin-btn btn-secondary" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
