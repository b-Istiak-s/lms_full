@model List<LibraryManagementSystem.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Members";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Manage Members</h1>
                <p class="admin-section-copy">Review registered member accounts and remove records when needed.</p>
            </div>
            <div class="admin-btn-group">
                <a class="btn admin-btn btn-primary" asp-action="Add">Add Member</a>
                <a class="btn admin-btn btn-light" asp-controller="Admin" asp-action="Index">Dashboard</a>
            </div>
        </div>

        @if (TempData["MemberMessage"] != null)
        {
            <p class="success-message">@TempData["MemberMessage"]</p>
        }

        @if (!Model.Any())
        {
            <p class="admin-empty">No member accounts found.</p>
        }
        else
        {
            <div class="admin-data-panel">
                <div class="table-scroll">
                <table class="data-table admin-data-table">
                    <thead>
                        <tr>
                            <th>Member ID</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model)
                        {
                            <tr>
                                <td>@member.Id</td>
                                <td>@member.FullName</td>
                                <td>@member.Email</td>
                                <td>
                                    <a class="btn admin-btn btn-secondary me-2" asp-action="Edit" asp-route-id="@member.Id">Edit</a>
                                    <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this member account?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@member.Id" />
                                        <button class="btn admin-btn btn-danger" type="submit">Delete Member</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        }
    </div>
</section>
