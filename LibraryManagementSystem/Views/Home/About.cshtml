@model LibraryManagementSystem.Models.LibraryProfile
@{
    ViewData["Title"] = "About";
}

<div class="container mt-4">
    @if (Model == null)
    {
        <h2>About</h2>
        <p>Library information is not available.</p>
    }
    else
    {
        <h1 class="mb-3">@Model.Name</h1>

        <div class="mb-2">
            <strong>Location:</strong>
            <span class="ms-2">@(!string.IsNullOrWhiteSpace(Model.Location) ? Model.Location : "Not specified")</span>
        </div>

        <div class="mb-2">
            <strong>Operating Hours:</strong>
            <span class="ms-2">@(!string.IsNullOrWhiteSpace(Model.OperatingHours) ? Model.OperatingHours : "Not specified")</span>
        </div>

        <div class="mb-2">
            <strong>Contact:</strong>
            <span class="ms-2">@(!string.IsNullOrWhiteSpace(Model.ContactDetails) ? Model.ContactDetails : "Not specified")</span>
        </div>
    }
</div>
