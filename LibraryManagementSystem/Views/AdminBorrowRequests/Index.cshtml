@model List<LibraryManagementSystem.Models.BorrowTransaction>
@using LibraryManagementSystem.Models
@{
    ViewData["Title"] = "Borrowed Books";
    var members = ViewBag.Members as Dictionary<string, ApplicationUser> ?? new Dictionary<string, ApplicationUser>();
    var statusFilter = ViewBag.StatusFilter as string ?? "all";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Borrowed Books</h1>
                <p class="admin-section-copy">Track open and returned borrow records, calculate fines, and mark payments.</p>
            </div>
            <a class="btn admin-btn btn-light" asp-controller="Admin" asp-action="Index">Dashboard</a>
        </div>

        @if (TempData["AdminBorrowMessage"] != null)
        {
            <p class="success-message">@TempData["AdminBorrowMessage"]</p>
        }

        <form asp-action="Index" method="get" class="admin-filter-bar">
            <select name="status">
                <option value="all" selected="@(statusFilter == "all")">All records</option>
                <option value="borrowed" selected="@(statusFilter == "borrowed")">Currently borrowed</option>
                <option value="returned" selected="@(statusFilter == "returned")">Returned</option>
            </select>
            <button class="btn admin-btn btn-primary" type="submit">Filter</button>
            <a class="btn admin-btn btn-secondary" asp-action="Index">Clear</a>
        </form>

        @if (!Model.Any())
        {
            <p class="admin-empty">No borrow records found.</p>
        }
        else
        {
            <div class="admin-data-panel">
                <div class="table-scroll">
                <table class="data-table admin-data-table">
                    <thead>
                        <tr>
                            <th>Record ID</th>
                            <th>Member ID</th>
                            <th>Member</th>
                            <th>Book</th>
                            <th>ISBN</th>
                            <th>Borrow Date</th>
                            <th>Due Date</th>
                            <th>Return Date</th>
                            <th>Status</th>
                            <th>Fine</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model)
                        {
                            var member = members.ContainsKey(tx.UserId) ? members[tx.UserId] : null;
                            <tr>
                                <td>@tx.BorrowTransactionId</td>
                                <td>@tx.UserId</td>
                                <td>
                                    @(member?.FullName ?? tx.UserId)<br />
                                    <span class="muted">@(member?.Email ?? "")</span>
                                </td>
                                <td>@(tx.Book?.Title ?? "Unknown")</td>
                                <td>@(tx.Book?.ISBN ?? "-")</td>
                                <td>@tx.BorrowDate.ToShortDateString()</td>
                                <td>@tx.DueDate.ToShortDateString()</td>
                                <td>@(tx.ReturnDate.HasValue ? tx.ReturnDate.Value.ToShortDateString() : "-")</td>
                                <td>
                                    <span class="admin-status-pill @(tx.IsReturned ? "available" : "unavailable")">
                                        @(tx.IsReturned ? "Returned" : "Borrowed")
                                    </span>
                                </td>
                                <td>
                                    @if (tx.Fine != null)
                                    {
                                        <span class="admin-status-pill @(tx.Fine.IsPaid ? "paid" : "unpaid")">
                                            $@tx.Fine.Amount.ToString("0.00") @(tx.Fine.IsPaid ? "Paid" : "Unpaid")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="muted">No fine</span>
                                    }
                                </td>
                                <td>
                                    <div class="admin-btn-group">
                                        @if (!tx.IsReturned)
                                        {
                                            <button type="button"
                                                    class="btn admin-btn btn-warning"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#returnModal"
                                                    data-id="@tx.BorrowTransactionId"
                                                    data-book='@(tx.Book?.Title ?? "Unknown")'
                                                    data-member='@(member?.FullName ?? tx.UserId)'
                                                    data-borrow-date='@tx.BorrowDate.ToString("yyyy-MM-dd")'>
                                                Return Book
                                            </button>
                                        }
                                        @if (tx.Fine != null && !tx.Fine.IsPaid)
                                        {
                                            <form asp-action="MarkFinePaid" method="post" class="inline-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@tx.Fine.FineId" />
                                                <button class="btn admin-btn btn-success" type="submit">Mark Fine Paid</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        }
    </div>
</section>

<div class="modal fade" id="returnModal" tabindex="-1" aria-labelledby="returnModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="returnModalLabel">Return Book and Calculate Fine</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Return" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="returnBorrowId" name="id" />
                    <div class="mb-3">
                        <label class="form-label">Book</label>
                        <input type="text" id="returnBookTitle" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Member</label>
                        <input type="text" id="returnMember" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Borrowing Date</label>
                        <input type="date" id="returnBorrowDate" name="borrowDate" class="form-control" required />
                        <small class="muted">Admin can correct the borrowing date before returning the book.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Return Date</label>
                        <input type="date" id="returnDate" name="returnDate" class="form-control" required />
                        <small class="muted">Fine is calculated automatically from the return date and due date.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn admin-btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn admin-btn btn-warning">Return and Calculate Fine</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const returnModal = document.getElementById('returnModal');
        returnModal?.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            if (!button) return;

            document.getElementById('returnBorrowId').value = button.getAttribute('data-id') ?? '';
            document.getElementById('returnBookTitle').value = button.getAttribute('data-book') ?? '';
            document.getElementById('returnMember').value = button.getAttribute('data-member') ?? '';
            document.getElementById('returnBorrowDate').value = button.getAttribute('data-borrow-date') ?? '';
            document.getElementById('returnDate').valueAsDate = new Date();
        });
    </script>
}
