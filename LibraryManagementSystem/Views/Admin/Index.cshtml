@* Person 3: Admin dashboard for librarian management features. *@
@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="admin-dashboard admin-surface">
    <div class="admin-dashboard-top">
        <div class="admin-brandline">
            <div class="admin-brandmark">
                <img src="~/images/static/profile.png" alt="Library brand" />
                <span>Library Hub</span>
            </div>
            <div class="admin-welcome">
                <p class="admin-welcome-kicker">Admin</p>
                <h1 class="admin-welcome-title">WELCOME</h1>
            </div>
            <div class="record-count">Dashboard Overview</div>
        </div>
        <div class="admin-crumbs">
            <div><strong>Dashboard</strong></div>
            <div>Admin &gt; Dashboard</div>
        </div>
    </div>

    <div class="admin-dashboard-grid">
        <a class="admin-dashboard-card admin-card-lilac" asp-controller="LibraryProfile" asp-action="Edit">
            <img class="admin-card-image" src="~/images/static/profile.png" alt="" />
            <h2 class="admin-card-title">Library Profile</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Update library details, contact info, and borrowing rules.</p>
                <span class="admin-card-count">Edit</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-green" asp-controller="AdminMembers" asp-action="Index">
            <img class="admin-card-image" src="~/images/static/profile.png" alt="" />
            <h2 class="admin-card-title">View Members</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Open the member list and manage registrations.</p>
                <span class="admin-card-count">@ViewBag.MemberCount</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-lime" asp-controller="Books" asp-action="Create">
            <img class="admin-card-image" src="~/images/static/stack-of-books.png" alt="" />
            <h2 class="admin-card-title">Add Books</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Create a catalog record and upload a cover image.</p>
                <span class="admin-card-count">@ViewBag.TotalBooks</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-orange" asp-controller="Books" asp-action="Index">
            <img class="admin-card-image" src="~/images/static/stack-of-books.png" alt="" />
            <h2 class="admin-card-title">View Books</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Browse inventory, availability, and live borrowers.</p>
                <span class="admin-card-count">@ViewBag.AvailableBooks</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-coral" asp-controller="AdminBorrowRequests" asp-action="Index" asp-route-status="borrowed">
            <img class="admin-card-image" src="~/images/static/borrow.png" alt="" />
            <h2 class="admin-card-title">Borrowed Books</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Track active loans and complete returns.</p>
                <span class="admin-card-count">@ViewBag.BorrowedBooks</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-slate" asp-controller="Fines" asp-action="Index">
            <img class="admin-card-image" src="~/images/static/fine.png" alt="" />
            <h2 class="admin-card-title">Fines</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Check fines, payments, and closed borrowing records.</p>
                <span class="admin-card-count">@ViewBag.UnpaidFines</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-olive" asp-controller="Borrow" asp-action="Index">
            <img class="admin-card-image" src="~/images/static/borrow.png" alt="" />
            <h2 class="admin-card-title">Book History</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Inspect manual borrowing history and fine updates.</p>
                <span class="admin-card-count">@ViewBag.BorrowedBooks</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-sage" asp-controller="Reports" asp-action="Index">
            <img class="admin-card-image" src="~/images/static/report.png" alt="" />
            <h2 class="admin-card-title">Reports</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Open reports, reservations, and profile controls.</p>
                <span class="admin-card-count">@ViewBag.PendingReservations</span>
            </div>
        </a>

        <a class="admin-dashboard-card admin-card-slate" asp-controller="AdminFeedback" asp-action="Index">
            <img class="admin-card-image" src="~/images/static/report.png" alt="" />
            <h2 class="admin-card-title">Feedback</h2>
            <div class="admin-card-meta">
                <p class="admin-card-caption">Read member feedback and rating submissions.</p>
                <span class="admin-card-count">@ViewBag.FeedbackCount</span>
            </div>
        </a>

        <form asp-controller="Account" asp-action="Logout" method="post" class="admin-signout-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="admin-dashboard-card admin-card-magenta">
                <img class="admin-card-image" src="~/images/static/reserve.png" alt="" />
                <h2 class="admin-card-title">Sign Out</h2>
                <div class="admin-card-meta">
                    <p class="admin-card-caption">Leave the admin console safely.</p>
                    <span class="admin-card-count">Exit</span>
                </div>
            </button>
        </form>
    </div>
</section>
