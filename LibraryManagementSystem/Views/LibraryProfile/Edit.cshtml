@* Person 3: Library profile and borrowing rules edit page. *@
@model LibraryManagementSystem.Models.LibraryProfile
@{
    ViewData["Title"] = "Library Profile";
    var rule = ViewBag.BorrowRule as LibraryManagementSystem.Models.BorrowRule ?? new LibraryManagementSystem.Models.BorrowRule { MaxBooks = 5, LoanDays = 14, FinePerDay = 2.00m };
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Library Profile</h1>
                <p class="admin-section-copy">Set the public library details and update borrowing policy from one admin page.</p>
            </div>
            <a class="btn admin-btn btn-light" asp-controller="Admin" asp-action="Index">Dashboard</a>
        </div>

        @if (TempData["ProfileSaved"] != null)
        {
            <div class="alert alert-success">@TempData["ProfileSaved"]</div>
        }

        <div class="admin-form-layout">
            <div class="admin-form-card">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="admin-form-grid">
                        <div class="admin-field">
                            <label asp-for="Name"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label asp-for="Location"></label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="admin-field">
                            <label asp-for="OperatingHours">Operating Hours</label>
                            <input asp-for="OperatingHours" class="form-control" placeholder="Example: 9:00 AM - 5:00 PM" />
                        </div>

                        <div class="admin-field">
                            <label asp-for="ContactDetails">Contact Details</label>
                            <input asp-for="ContactDetails" class="form-control" placeholder="Example: library@example.com" />
                        </div>

                        <div class="admin-field">
                            <label>Maximum Borrowable Books</label>
                            <input type="number" name="maxBooks" value="@rule.MaxBooks" min="1" class="form-control" required />
                        </div>

                        <div class="admin-field">
                            <label>Loan Duration Days</label>
                            <input type="number" name="loanDays" value="@rule.LoanDays" min="1" class="form-control" required />
                        </div>

                        <div class="admin-field full">
                            <label>Fine Per Overdue Day</label>
                            <input type="number" step="0.01" name="finePerDay" value="@rule.FinePerDay" min="0" class="form-control" required />
                        </div>
                    </div>

                    <div class="admin-form-actions">
                        <button type="submit" class="btn admin-btn btn-primary">Save Settings</button>
                        <a class="btn admin-btn btn-secondary" asp-controller="Admin" asp-action="Index">Back to Dashboard</a>
                    </div>
                </form>
            </div>

            <aside class="admin-side-card">
                <h2 class="h4 mb-3">Policy notes</h2>
                <ul class="admin-side-list">
                    <li>Changes to loan duration affect future due-date calculations.</li>
                    <li>Fine per day is used automatically when books are returned late.</li>
                    <li>Contact details and operating hours appear in the library profile record.</li>
                </ul>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
