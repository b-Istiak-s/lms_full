@* Person 3: Library profile and borrowing rules edit page. *@
@model LibraryManagementSystem.Models.LibraryProfile
@{
    ViewData["Title"] = "Library Profile";
    var rule = ViewBag.BorrowRule as LibraryManagementSystem.Models.BorrowRule ?? new LibraryManagementSystem.Models.BorrowRule { MaxBooks = 5, LoanDays = 14, FinePerDay = 2.00m };
}

<h2>Library Profile and Borrowing Rules</h2>

@if (TempData["ProfileSaved"] != null)
{
    <div class="alert alert-success">@TempData["ProfileSaved"]</div>
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <h4>Library Details</h4>
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Location" class="form-label"></label>
        <input asp-for="Location" class="form-control" />
        <span asp-validation-for="Location" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="OperatingHours" class="form-label">Operating Hours</label>
        <input asp-for="OperatingHours" class="form-control" placeholder="Example: 9:00 AM - 5:00 PM" />
    </div>
    <div class="mb-3">
        <label asp-for="ContactDetails" class="form-label">Contact Details</label>
        <input asp-for="ContactDetails" class="form-control" placeholder="Example: library@example.com" />
    </div>

    <h4>Borrowing Rules</h4>
    <div class="mb-3">
        <label class="form-label">Maximum Borrowable Books</label>
        <input type="number" name="maxBooks" value="@rule.MaxBooks" min="1" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Loan Duration Days</label>
        <input type="number" name="loanDays" value="@rule.LoanDays" min="1" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Fine Per Overdue Day</label>
        <input type="number" step="0.01" name="finePerDay" value="@rule.FinePerDay" min="0" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-controller="Admin" asp-action="Index">Back to Dashboard</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
