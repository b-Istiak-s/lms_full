@* Person 3: Reservation management page. *@
@model IEnumerable<LibraryManagementSystem.Models.Reservation>
@{
    ViewData["Title"] = "Reservations";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Reservations</h1>
                <p class="admin-section-copy">Review reserved books with member details, status, and the original reservation date.</p>
            </div>
            <a class="btn admin-btn btn-light" asp-controller="Admin" asp-action="Index">Dashboard</a>
        </div>

        @if (!Model.Any())
        {
            <p class="admin-empty">No reservations found.</p>
        }
        else
        {
            <div class="admin-data-panel">
                <table class="data-table admin-data-table">
                    <thead>
                        <tr>
                            <th>Reservation ID</th>
                            <th>Member ID / Email</th>
                            <th>Book</th>
                            <th>ISBN</th>
                            <th>Author</th>
                            <th>Genre</th>
                            <th>Book Status</th>
                            <th>Reservation Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.ReservationId</td>
                            <td>@r.UserId</td>
                            <td>@r.Book?.Title</td>
                            <td>@r.Book?.ISBN</td>
                            <td>@r.Book?.Author?.Name</td>
                            <td>@r.Book?.Genre?.Name</td>
                            <td>
                                <span class="admin-status-pill @((r.Book?.IsAvailable == true) ? "available" : "unavailable")">
                                    @((r.Book?.IsAvailable == true) ? "Available" : "Unavailable")
                                </span>
                            </td>
                            <td>@r.ReservationDate.ToShortDateString()</td>
                            <td>
                                <form asp-action="Cancel" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.ReservationId" />
                                    <button class="btn admin-btn btn-danger">Cancel</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
