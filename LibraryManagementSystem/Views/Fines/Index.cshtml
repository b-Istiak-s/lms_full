@* Person 3: Fine management page. *@
@model IEnumerable<LibraryManagementSystem.Models.Fine>
@using LibraryManagementSystem.Models
@{
    ViewData["Title"] = "Fines";
    var users = ViewBag.Users as Dictionary<string, ApplicationUser> ?? new Dictionary<string, ApplicationUser>();
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Fines</h1>
                <p class="admin-section-copy">Track overdue charges and mark payments as they are settled.</p>
            </div>
            <a class="btn admin-btn btn-light" asp-controller="Admin" asp-action="Index">Dashboard</a>
        </div>

        <div class="admin-data-panel">
            <div class="table-scroll">
            <table class="data-table admin-data-table">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>User Name</th>
                        <th>Amount</th>
                        <th>Paid</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var f in Model)
                {
                    var user = f.BorrowTransaction?.UserId != null && users.ContainsKey(f.BorrowTransaction.UserId) ? users[f.BorrowTransaction.UserId] : null;
                    <tr>
                        <td>@f.BorrowTransaction?.Book?.Title</td>
                        <td>
                            @(user?.FullName ?? user?.Email ?? f.BorrowTransaction?.UserId)
                            @if (!string.IsNullOrWhiteSpace(user?.Email) && !string.Equals(user?.FullName, user?.Email, StringComparison.OrdinalIgnoreCase))
                            {
                                <br />
                                <span class="muted">@user.Email</span>
                            }
                        </td>
                        <td>@f.Amount.ToString("C")</td>
                        <td>
                            <span class="admin-status-pill @(f.IsPaid ? "paid" : "unpaid")">
                                @(f.IsPaid ? "Paid" : "Unpaid")
                            </span>
                        </td>
                        <td>
                            @if (!f.IsPaid)
                            {
                                <form asp-action="MarkPaid" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@f.FineId" />
                                    <button class="btn admin-btn btn-success">Mark Paid</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</section>
