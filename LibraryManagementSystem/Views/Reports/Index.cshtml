@* Person 3: Admin reports page for library activity summary. *@
@{
    ViewData["Title"] = "Reports";
}

<section class="admin-page">
    <div class="admin-page-card admin-surface">
        <div class="admin-section-header">
            <div>
                <h1 class="admin-section-title">Reports</h1>
                <p class="admin-section-copy">Quick snapshot of stock, active borrowing, and unpaid fines.</p>
            </div>
            <div class="admin-btn-group">
                <a class="btn admin-btn btn-light" asp-controller="Reservation" asp-action="Index">Reservations</a>
                <a class="btn admin-btn btn-secondary" asp-controller="Admin" asp-action="Index">Dashboard</a>
            </div>
        </div>

        <div class="admin-summary-grid">
            <div class="admin-summary-card"><span>Total Books</span><strong>@ViewBag.TotalBooks</strong></div>
            <div class="admin-summary-card"><span>Currently Borrowed</span><strong>@ViewBag.Borrowed</strong></div>
            <div class="admin-summary-card"><span>Unpaid Fines</span><strong>@ViewBag.UnpaidFines.ToString("C")</strong></div>
        </div>
    </div>
</section>
